---
import Layout from "../layouts/Layout.astro";
import SiteIcon from "../components/SiteIcon.tsx";
---

<Layout title="Sabari Works  Video Editor & Motion Designer">
<style>
  .hero {
    min-height: calc(100vh - 66px);
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 60px;
    padding: 48px 8%;
  }
  @media (max-width: 900px) {
    .hero { grid-template-columns: 1fr; padding: 60px 6%; gap: 40px; }
    .hero-visual { order: -1; }
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 20px;
    background: rgba(14,165,233,0.08);
    border: 1px solid rgba(14,165,233,0.2);
    padding: 5px 14px;
    border-radius: 20px;
    width: fit-content;
  }
  .hero-eyebrow::before { content: ''; display: block; width: 6px; height: 6px; background: var(--accent); border-radius: 50%; }

  .hero-text h1 {
    font-size: clamp(26px, 3.5vw, 42px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -1px;
    margin-bottom: 14px;
    color: var(--text);
  }
  .hero-text h1 em {
    font-style: normal;
    color: var(--accent);
  }

  .hero-tagline {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.65;
    max-width: 440px;
    margin-bottom: 24px;
  }

  .hero-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 40px;
  }
  .pill {
    font-size: 12px;
    font-weight: 500;
    color: var(--muted);
    background: var(--surface-alt);
    border: 1px solid var(--border);
    padding: 4px 12px;
    border-radius: 20px;
  }

  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--accent);
    color: #fff;
    font-weight: 600;
    font-size: 14px;
    padding: 12px 24px;
    border-radius: 10px;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 2px 12px rgba(14,165,233,0.3);
  }
  .btn-primary:hover { background: var(--accent-dark); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(14,165,233,0.4); }
  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--border-strong);
    color: var(--text);
    font-weight: 500;
    font-size: 14px;
    padding: 12px 24px;
    border-radius: 10px;
    transition: border-color 0.2s, background 0.2s, transform 0.2s;
  }
  .btn-outline:hover { border-color: var(--accent); background: rgba(14,165,233,0.04); transform: translateY(-2px); }

  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .profile-wrap {
    position: relative;
    width: 360px;
    max-width: 100%;
  }
  @media (max-width: 900px) {
    .profile-wrap { width: 240px; }
  }
  .profile-ring {
    position: absolute;
    inset: -16px;
    border-radius: 999px;
    background: conic-gradient(from 180deg, rgba(14,165,233,0.35), rgba(124,58,237,0.25), transparent 60%);
    animation: spin 10s linear infinite;
    pointer-events: none;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .profile-glow {
    position: absolute;
    inset: -40px;
    background: radial-gradient(circle, rgba(14,165,233,0.12) 0%, transparent 65%);
    pointer-events: none;
    border-radius: 50%;
  }
  .profile-img {
    width: 100%;
    aspect-ratio: 1/1;
    object-fit: cover;
    object-position: top center;
    border-radius: 999px;
    display: block;
    border: 4px solid var(--surface);
    box-shadow: 0 24px 64px rgba(14,165,233,0.18), 0 4px 24px rgba(0,0,0,0.1);
    position: relative;
    z-index: 1;
  }
  .profile-badge {
    position: absolute;
    bottom: 16px;
    right: -12px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 8px 14px;
    box-shadow: var(--shadow-lg);
    font-size: 12px;
    font-weight: 600;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 6px;
    z-index: 2;
    white-space: nowrap;
  }
  .profile-badge::before { content: ''; width: 8px; height: 8px; border-radius: 50%; background: #22c55e; flex-shrink: 0; }
  .showreel-section {
    padding: 0 8% 80px;
    background: var(--bg);
    position: relative;
    z-index: 1;
  }
  .showreel-label-top {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 16px;
  }
  .showreel-frame {
    border-radius: 18px;
    overflow: hidden;
    background: var(--surface);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-lg);
    position: relative;
    max-width: 800px;
  }
  .showreel-frame iframe { aspect-ratio: 16/9; border-radius: 0; width: 100%; display: block; }

  .hero-stats {
    display: flex;
    gap: 32px;
    margin-top: 32px;
  }
  .stat-num {
    font-family: 'Syne', sans-serif;
    font-size: 28px;
    font-weight: 800;
    color: var(--text);
    line-height: 1;
    margin-bottom: 4px;
  }
  .stat-label { font-size: 12px; color: var(--muted); font-weight: 500; }

  .scroll-hint {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: var(--muted);
    margin-top: 32px;
    font-weight: 500;
  }
  .scroll-hint span { width: 24px; height: 1px; background: var(--border-strong); }

  /* ── SKILLS GLIMPSE ── */
  .glimpse-section {
    padding: 0 8% 56px;
  }
  .glimpse-label {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 18px;
  }
  .glimpse-label h2 {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0;
  }
  .glimpse-label a {
    font-size: 12px;
    font-weight: 600;
    color: var(--accent);
    display: flex;
    align-items: center;
    gap: 4px;
    transition: gap 0.2s;
  }
  .glimpse-label a:hover { gap: 8px; }
  .skills-glimpse-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 12px;
  }
  @media (max-width: 900px) {
    .skills-glimpse-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 600px) {
    .skills-glimpse-grid { grid-template-columns: repeat(2, 1fr); }
  }
  .skill-glimpse-card {
    padding: 14px 14px 12px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    transition: border-color 0.2s, transform 0.2s;
  }
  .skill-glimpse-card:hover { transform: translateY(-3px); border-color: var(--sg-color, var(--accent)); }
  .sg-title {
    font-family: 'Syne', sans-serif;
    font-size: 11px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: 0.3px;
  }
  .sg-tools {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }
  .sg-tool {
    font-size: 10px;
    font-weight: 500;
    color: var(--sg-color, var(--accent));
    background: var(--sg-bg, rgba(14,165,233,0.08));
    border: 1px solid var(--sg-border, rgba(14,165,233,0.18));
    padding: 2px 7px;
    border-radius: 20px;
    white-space: nowrap;
  }

  /* ── PROJECTS SECTION ── */
  .projects-section {
    padding: 0 8% 56px;
  }
  .home-video-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 16px;
  }
  .home-video-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: transform 0.3s, border-color 0.3s, box-shadow 0.3s;
  }
  .home-video-card:hover {
    transform: translateY(-5px);
    border-color: var(--hvc-accent, var(--accent));
    box-shadow: var(--shadow-md), 0 0 0 2px color-mix(in srgb, var(--hvc-accent, var(--accent)) 15%, transparent);
  }
  .home-video-card iframe { aspect-ratio: 16/9; width: 100%; display: block; border: none; }
  .home-video-card.short iframe { aspect-ratio: 9/16; }
  .view-all-card {
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 16/9;
    text-decoration: none;
    background: var(--surface);
    border: 1px dashed var(--border-strong);
    border-radius: 14px;
    transition: border-color 0.3s, background 0.3s, transform 0.3s;
  }
  .view-all-card:hover {
    border-color: var(--accent);
    background: rgba(14,165,233,0.04);
    transform: translateY(-5px);
  }
  .view-all-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }
  .view-all-icon {
    width: 48px; height: 48px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    background: rgba(14,165,233,0.1);
    border: 1px solid rgba(14,165,233,0.2);
    color: var(--accent);
    transition: background 0.2s, transform 0.2s;
  }
  .view-all-card:hover .view-all-icon {
    background: var(--accent);
    color: #fff;
    transform: translateX(4px);
  }
  .view-all-text {
    font-family: 'Syne', sans-serif;
    font-size: 13px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: 0.3px;
  }
</style>

<section class="hero">
  <div class="hero-text">
    <div class="hero-eyebrow">Open for projects</div>
    <h1>Video Editor &amp;<br/><em>Motion Designer</em></h1>
    <p class="hero-tagline">
      Hi, I'm Sabari  I craft cinematic videos, motion graphics, VFX, and 3D visuals
      that make brands and stories come alive.
    </p>
    <div class="hero-pills">
      <span class="pill">Video Editing</span>
      <span class="pill">Motion Graphics</span>
      <span class="pill">VFX</span>
      <span class="pill">Color Grading</span>
      <span class="pill">3D Modelling</span>
    </div>
    <div class="hero-cta">
      <a href="/works" class="btn-primary">View My Work <SiteIcon name="arrowRight" size={14} /></a>
      <a href="/contact" class="btn-outline"><SiteIcon name="mail" size={14} /> Get in Touch</a>
    </div>
    <div class="hero-stats">
      <div>
        <div class="stat-num">20+</div>
        <div class="stat-label">Projects</div>
      </div>
      <div>
        <div class="stat-num">3+</div>
        <div class="stat-label">Years Exp.</div>
      </div>
      <div>
        <div class="stat-num">5</div>
        <div class="stat-label">Specialties</div>
      </div>
    </div>
  </div>

  <div class="hero-visual reveal">
    <div class="profile-wrap">
      <div class="profile-glow"></div>
      <div class="profile-ring"></div>
      <img src="/profile.jpeg" alt="Sabari JC — Video Editor & Motion Designer" class="profile-img" />
      <div class="profile-badge">Available for work</div>
    </div>
  </div>
</section>

<section class="showreel-section reveal">
  <div class="showreel-label-top">Showreel</div>
  <div class="showreel-frame">
    <iframe
      src="https://www.youtube.com/embed/x7VlLZrcX7Y"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
      loading="lazy">
    </iframe>
  </div>
</section>

<section class="glimpse-section reveal-group">
  <!-- Skills Glimpse -->
  <div class="glimpse-label">
    <h2>Skills</h2>
  </div>
  <div class="skills-glimpse-grid">
    {[
      { title: "Video Editing",   tools: ["Premiere Pro","After Effects","DaVinci"],  color: "#0ea5e9" },
      { title: "Motion Graphics", tools: ["After Effects"],                            color: "#7c3aed" },
      { title: "VFX",             tools: ["After Effects","Blender"],                  color: "#ec4899" },
      { title: "Colour Grading",  tools: ["DaVinci Resolve"],                          color: "#f59e0b" },
      { title: "3D Modelling",    tools: ["Maya","Blender"],                           color: "#10b981" },
    ].map(s => (
      <div
        class="skill-glimpse-card"
        style={`--sg-color:${s.color};--sg-bg:${s.color}12;--sg-border:${s.color}28;`}
      >
        <span class="sg-title">{s.title}</span>
        <div class="sg-tools">
          {s.tools.map(t => <span class="sg-tool">{t}</span>)}
        </div>
      </div>
    ))}
  </div>
</section>

<section class="projects-section reveal-group">
  <div class="glimpse-label" style="margin-bottom:28px;">
    <h2>Projects</h2>
  </div>
  <div class="home-video-grid">
    <div class="home-video-card" style="--hvc-accent:#ec4899;">
      <iframe src="https://www.youtube.com/embed/WrFH0C8b2Vs" allowfullscreen loading="lazy"></iframe>
    </div>
    <div class="home-video-card" style="--hvc-accent:#ec4899;">
      <iframe src="https://www.youtube.com/embed/B1L4l9uIiyg" allowfullscreen loading="lazy"></iframe>
    </div>
    <div class="home-video-card" style="--hvc-accent:#7c3aed;">
      <iframe src="https://www.youtube.com/embed/H7f4mMpvh8k" allowfullscreen loading="lazy"></iframe>
    </div>
    <a href="/works" class="home-video-card view-all-card">
      <div class="view-all-inner">
        <div class="view-all-icon"><SiteIcon name="arrowRight" size={22} /></div>
        <span class="view-all-text">View All Works</span>
      </div>
    </a>
  </div>
</section>


</Layout>
