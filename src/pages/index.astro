---
import Layout from "../layouts/Layout.astro";
import SiteIcon from "../components/SiteIcon.tsx";
---

<Layout title="Sabari Works  Video Editor & Motion Designer">
<style>
  .hero {
    min-height: calc(100vh - 66px);
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 60px;
    padding: 80px 8%;
  }
  @media (max-width: 900px) {
    .hero { grid-template-columns: 1fr; padding: 60px 6%; gap: 40px; }
    .hero-visual { order: -1; }
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 20px;
    background: rgba(14,165,233,0.08);
    border: 1px solid rgba(14,165,233,0.2);
    padding: 5px 14px;
    border-radius: 20px;
    width: fit-content;
  }
  .hero-eyebrow::before { content: ''; display: block; width: 6px; height: 6px; background: var(--accent); border-radius: 50%; }

  .hero-text h1 {
    font-size: clamp(36px, 5vw, 60px);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -1.5px;
    margin-bottom: 18px;
    color: var(--text);
  }
  .hero-text h1 em {
    font-style: normal;
    color: var(--accent);
  }

  .hero-tagline {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.75;
    max-width: 480px;
    margin-bottom: 36px;
  }

  .hero-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 40px;
  }
  .pill {
    font-size: 12px;
    font-weight: 500;
    color: var(--muted);
    background: var(--surface-alt);
    border: 1px solid var(--border);
    padding: 4px 12px;
    border-radius: 20px;
  }

  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--accent);
    color: #fff;
    font-weight: 600;
    font-size: 14px;
    padding: 12px 24px;
    border-radius: 10px;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 2px 12px rgba(14,165,233,0.3);
  }
  .btn-primary:hover { background: var(--accent-dark); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(14,165,233,0.4); }
  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--border-strong);
    color: var(--text);
    font-weight: 500;
    font-size: 14px;
    padding: 12px 24px;
    border-radius: 10px;
    transition: border-color 0.2s, background 0.2s, transform 0.2s;
  }
  .btn-outline:hover { border-color: var(--accent); background: rgba(14,165,233,0.04); transform: translateY(-2px); }

  .hero-visual {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .profile-wrap {
    position: relative;
    width: 360px;
    max-width: 100%;
  }
  @media (max-width: 900px) {
    .profile-wrap { width: 240px; }
  }
  .profile-ring {
    position: absolute;
    inset: -16px;
    border-radius: 999px;
    background: conic-gradient(from 180deg, rgba(14,165,233,0.35), rgba(124,58,237,0.25), transparent 60%);
    animation: spin 10s linear infinite;
    pointer-events: none;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .profile-glow {
    position: absolute;
    inset: -40px;
    background: radial-gradient(circle, rgba(14,165,233,0.12) 0%, transparent 65%);
    pointer-events: none;
    border-radius: 50%;
  }
  .profile-img {
    width: 100%;
    aspect-ratio: 1/1;
    object-fit: cover;
    object-position: top center;
    border-radius: 999px;
    display: block;
    border: 4px solid var(--surface);
    box-shadow: 0 24px 64px rgba(14,165,233,0.18), 0 4px 24px rgba(0,0,0,0.1);
    position: relative;
    z-index: 1;
  }
  .profile-badge {
    position: absolute;
    bottom: 16px;
    right: -12px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 8px 14px;
    box-shadow: var(--shadow-lg);
    font-size: 12px;
    font-weight: 600;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 6px;
    z-index: 2;
    white-space: nowrap;
  }
  .profile-badge::before { content: ''; width: 8px; height: 8px; border-radius: 50%; background: #22c55e; flex-shrink: 0; }
  .showreel-section {
    padding: 0 8% 80px;
    background: var(--bg);
    position: relative;
    z-index: 1;
  }
  .showreel-label-top {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 16px;
  }
  .showreel-frame {
    border-radius: 18px;
    overflow: hidden;
    background: var(--surface);
    border: 1px solid var(--border);
    box-shadow: var(--shadow-lg);
    position: relative;
    max-width: 800px;
  }
  .showreel-frame iframe { aspect-ratio: 16/9; border-radius: 0; width: 100%; display: block; }

  .hero-stats {
    display: flex;
    gap: 32px;
    margin-top: 32px;
  }
  .stat-num {
    font-family: 'Syne', sans-serif;
    font-size: 28px;
    font-weight: 800;
    color: var(--text);
    line-height: 1;
    margin-bottom: 4px;
  }
  .stat-label { font-size: 12px; color: var(--muted); font-weight: 500; }

  .scroll-hint {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: var(--muted);
    margin-top: 32px;
    font-weight: 500;
  }
  .scroll-hint span { width: 24px; height: 1px; background: var(--border-strong); }
</style>

<section class="hero">
  <div class="hero-text">
    <div class="hero-eyebrow">Open for projects</div>
    <h1>Video Editor &amp;<br/><em>Motion Designer</em></h1>
    <p class="hero-tagline">
      Hi, I'm Sabari  I craft cinematic videos, motion graphics, VFX, and 3D visuals
      that make brands and stories come alive.
    </p>
    <div class="hero-pills">
      <span class="pill">Video Editing</span>
      <span class="pill">Motion Graphics</span>
      <span class="pill">VFX</span>
      <span class="pill">Color Grading</span>
      <span class="pill">3D Modelling</span>
    </div>
    <div class="hero-cta">
      <a href="/works" class="btn-primary">View My Work <SiteIcon name="arrowRight" size={14} /></a>
      <a href="/contact" class="btn-outline"><SiteIcon name="mail" size={14} /> Get in Touch</a>
    </div>
    <div class="hero-stats">
      <div>
        <div class="stat-num">50+</div>
        <div class="stat-label">Projects</div>
      </div>
      <div>
        <div class="stat-num">3+</div>
        <div class="stat-label">Years Exp.</div>
      </div>
      <div>
        <div class="stat-num">5</div>
        <div class="stat-label">Specialties</div>
      </div>
    </div>
  </div>

  <div class="hero-visual reveal">
    <div class="profile-wrap">
      <div class="profile-glow"></div>
      <div class="profile-ring"></div>
      <img src="/profile.jpeg" alt="Sabari JC — Video Editor & Motion Designer" class="profile-img" />
      <div class="profile-badge">Available for work</div>
    </div>
  </div>
</section>

<section class="showreel-section reveal">
  <div class="showreel-label-top">Showreel</div>
  <div class="showreel-frame">
    <iframe
      src="https://www.youtube.com/embed/x7VlLZrcX7Y"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
      loading="lazy">
    </iframe>
  </div>
</section>


</Layout>
